<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="TMGS4SaveEditor.App"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <ResourceDictionary>

            <Color x:Key="ColorTextMain">#4a4a4a</Color>
            <Color x:Key="ColorTextDark">#111111</Color>
            <Color x:Key="ColorWhite">#FFFFFF</Color>
            <Color x:Key="ColorAppBackground">#fff3ce</Color>
            <Color x:Key="ColorAppTextOnBackground">#4a4a4a</Color>

            <Color x:Key="ColorControlBgHover">#FAFAFA</Color>
            <Color x:Key="ColorControlBgPressed">#E8E8E8</Color>
            <Color x:Key="ColorControlBorderMain">#D3D3D3</Color>
            <Color x:Key="ColorControlBorderHover">#B0B0B0</Color>
            <Color x:Key="ColorControlBorderPressed">#909090</Color>

            <Color x:Key="ColorLoadMain">#ef8fb9</Color>
            <Color x:Key="ColorLoadHover">#e76d8c</Color>
            <Color x:Key="ColorLoadPressed">#dd5276</Color>

            <Color x:Key="ColorSaveMain">#f18714</Color>
            <Color x:Key="ColorSaveHover">#eb611d</Color>
            <Color x:Key="ColorSavePressed">#e34d12</Color>

            <Color x:Key="ColorPrimaryMain">#ef8fb9</Color>
            <Color x:Key="ColorPrimaryHover">#e76d8c</Color>
            <Color x:Key="ColorPrimaryPressed">#dd5276</Color>

            <Color x:Key="ColorSecondaryMain">#f18714</Color>
            <Color x:Key="ColorSecondaryHover">#eb611d</Color>
            <Color x:Key="ColorSecondaryPressed">#e34d12</Color>

            <Color x:Key="ColorHighlightHover">#f7e460</Color>
            <Color x:Key="ColorHighlightSelected">#d0d952</Color>
            <Color x:Key="ColorHighlightSelectedHover">#adcf3c</Color>

            <Color x:Key="ColorBorderMain">#f18714</Color> 
            <Color x:Key="ColorBorderHover">#f18714</Color> <!--eb611d-->
            <Color x:Key="ColorBorderPressed">#f18714</Color> <!--e34d12-->

            <Color x:Key="ColorLink">#eb611d</Color>

            <Color x:Key="ColorTextSelectionBackground">#ffc59f</Color>
            <Color x:Key="ColorTextSelectionForeground">#333333</Color>

            <!--DATE PICKER-->

            <Color x:Key="DatePickerHighlight">#ffe7ad</Color>

            <Color x:Key="AcceptButtonMain">#ded7ff</Color>
            <Color x:Key="AcceptButtonHover">#b2bdf6</Color>
            <Color x:Key="AcceptButtonPressed">#a5b2f7</Color>
            <Color x:Key="AcceptButtonIcon">#8491da</Color>

            <Color x:Key="DismissButtonMain">#ffd8de</Color>
            <Color x:Key="DismissButtonHover">#ffb6bd</Color>
            <Color x:Key="DismissButtonPressed">#ffaaa5</Color>
            <Color x:Key="DismissButtonIcon">#e76d8c</Color>

            <Color x:Key="ArrowButtonMain">#ffcb6b</Color>
            <Color x:Key="ArrowButtonHover">#f4b64a</Color>
            <Color x:Key="ArrowButtonPressed">#edad3c</Color>
            <Color x:Key="ArrowButtonIcon">#846438</Color>

            <!--CHEAT MENU-->

            <Color x:Key="GenCheatButtonMain">#ffcb6b</Color>
            <Color x:Key="GenCheatButtonHover">#f4b64a</Color>
            <Color x:Key="GenCheatButtonPressed">#edad3c</Color>
            <Color x:Key="GenCheatButtonText">#846438</Color>

            <Color x:Key="GuyCheatButtonMain">#d0d3ff</Color>
            <Color x:Key="GuyCheatButtonHover">#b1c2fb</Color>
            <Color x:Key="GuyCheatButtonPressed">#9db2ff</Color>
            <Color x:Key="GuyCheatButtonText">#6b82ce</Color>

            <Color x:Key="FriendCheatButtonMain">#ffd8e1</Color>
            <Color x:Key="FriendCheatButtonHover">#ffc5de</Color>
            <Color x:Key="FriendCheatButtonPressed">#feafd6</Color>
            <Color x:Key="FriendCheatButtonText">#ff82de</Color>

            <Color x:Key="OkButtonMain">#e4007f</Color>
            <Color x:Key="OkButtonHover">#ca0260</Color>
            <Color x:Key="OkButtonPressed">#b60145</Color>
            <Color x:Key="OkButtonText">#bd6d18</Color>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme DensityStyle="Compact" />

        <StyleInclude Source="avares://TMGSSaveEditor.Core/CoreStyles.axaml" />
    </Application.Styles>
</Application>
